# ─────────────────────────────────────────────────────────────────────────────
# Pretty Good AI — Voice Tester  ·  environment configuration
# Copy this file to `.env` and fill in the values. NEVER commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Vapi ───────────────────────────────────────────────────────────
# Get these from https://dashboard.vapi.ai
#   1. API key:        Dashboard → top-right org menu → "API Keys" → copy the
#                      *Private* key (starts with a UUID). NOT the public key.
#   2. Phone number:   Dashboard → "Phone Numbers" → create a free Vapi number
#                      (or import a Twilio number). Copy its ID (a UUID) below,
#                      and put the actual number (E.164) in CALLER_NUMBER.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# The single E.164 number your bot calls FROM (the Vapi number above).
# This is the number you report on the submission form. Example: +18885551234
CALLER_NUMBER=

# ── The number we are testing (do not change unless instructed) ──────────────
PGAI_TEST_NUMBER=+18054398008

# ── In-call "patient" brain (runs inside Vapi on its bundled credits) ────────
# Defaults are tuned for low latency + low cost + lucid conversation.
PATIENT_MODEL_PROVIDER=openai
PATIENT_MODEL=gpt-4o
# Vapi native voices are low-latency and cost-efficient (no ElevenLabs bill).
# Each persona picks its own voice; this is only the fallback.
PATIENT_VOICE_PROVIDER=vapi
PATIENT_VOICE_ID=Elliot
TRANSCRIBER_PROVIDER=deepgram
TRANSCRIBER_MODEL=nova-2

# ── Call + cost guardrails ───────────────────────────────────────────────────
# Hard ceiling on cumulative spend across a run. The orchestrator reads the real
# per-call cost Vapi reports and ABORTS before placing a call that would exceed
# this. Keep it comfortably under the challenge's ~$20 guidance.
SPEND_CAP_USD=12
# Per-call max duration (seconds). Target calls are 1–3 min.
MAX_CALL_SECONDS=210
# Poll interval / timeout while waiting for a call to finish.
POLL_INTERVAL_SECONDS=6
CALL_TIMEOUT_SECONDS=420

# ── OPTIONAL: automated bug-analysis pass (`python main.py analyze`) ──────────
# Only needed for the automated LLM analysis. Set exactly one provider's key.
# If neither is set, you can still write the bug report by hand from transcripts.
ANALYZER_PROVIDER=openai
ANALYZER_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
